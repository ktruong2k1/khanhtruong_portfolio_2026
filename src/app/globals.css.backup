@import "tailwindcss";

@theme {
  --font-sans: var(--font-sans), sans-serif;
  --font-serif: var(--font-serif), serif;
  
  /* Style Guide Colors */
  --color-brand-100: #CAF3E2;
  --color-brand-200: #A7EFC2;
  --color-brand-300: #57E08A;
  --color-brand-400: #22C55E;
  --color-brand-500: #16813D;
  --color-brand-600: #19704C;
  --color-brand-1000: #17211B;
  --color-brand-accent: #2ECC8A;

  --color-sec-100: #F7EBCD;
  --color-sec-200: #F0D89A;
  --color-sec-300: #E8C468;
  --color-sec-400: #E0AF32;
  --color-sec-500: #B88C1C;
  --color-sec-600: #826314;

  --color-neutral-100: #FFFFFF;
  --color-neutral-200: #E5E5E5;
  --color-neutral-300: #CCCCCC;
  --color-neutral-400: #B2B2B2;
  --color-neutral-500: #989898;
  --color-neutral-600: #7F7F7F;
  --color-neutral-700: #656565;
  --color-neutral-800: #4B4B4B;
  --color-neutral-900: #323232;
  --color-neutral-1000: #0B0B0C;

  --color-red-100: #FB3748;
  --color-red-200: #D00416;

  --color-yellow-100: #FFDB43;
  --color-yellow-200: #DFB400;

  --color-status-100: #84EBB4;
  --color-status-200: #1FC16B;

  /* Corner Radius */
  --radius-none: 0px;
  --radius-1: 4px;
  --radius-2: 8px;
  --radius-3: 12px;
  --radius-4: 16px;
  --radius-5: 20px;
  --radius-6: 24px;
  --radius-7: 32px;
  --radius-8: 40px;
  --radius-full: 999px;

  /* Spacings */
  --spacing-3xs: 2px;
  --spacing-2xs: 4px;
  --spacing-xs: 8px;
  --spacing-s: 12px;
  --spacing-m: 16px;
  --spacing-l: 20px;
  --spacing-xl: 24px;
  --Spacing-xl: 24px;
  --spacing-2xl: 32px;
  --spacing-3xl: 40px;
  --spacing-4xl: 48px;
  --spacing-5xl: 56px;
  --spacing-6xl: 64px;
  --spacing-no-spacing: 0px;
}

:root {
  --Colors-Neutral-1000: #0B0B0C;
  --Spacing-xl: 24px;
  --Spacing-s: 12px;
  --Spacing-Padding-2XS: 2px;
  --Spacing-Padding-S: 8px;
  --Spacing-Padding-XS: 4px;
  --Radius-Round: 9999px;
  --background: var(--Colors-Neutral-1000, #0B0B0C);
  --foreground: #FFFFFF;

  /* Responsive layout padding (fluid) */
  --side-padding: clamp(20px, calc(20px + (120 - 20) * ((100vw - 375px) / (1280 - 375))), 120px);

  /* Fluid typography scaling (15% down on mobile) */
  --font-size-hero-title: clamp(29px, calc(29px + (34 - 29) * ((100vw - 375px) / (1280 - 375))), 34px);
  --font-size-hero-subhead: clamp(17px, calc(17px + (20 - 17) * ((100vw - 375px) / (1280 - 375))), 20px);
  --font-size-project-title: clamp(20px, calc(20px + (24 - 20) * ((100vw - 375px) / (1280 - 375))), 24px);
  --font-size-sidebar-title: clamp(15.5px, calc(15.5px + (18 - 15.5) * ((100vw - 375px) / (1280 - 375))), 18px);
  --font-size-body: clamp(12px, calc(12px + (14 - 12) * ((100vw - 375px) / (1280 - 375))), 14px);
}

.dark {
  --background: var(--Colors-Neutral-1000, #0B0B0C);
  --foreground: #FFFFFF;
}

body {
  background: var(--Colors-Neutral-1000, #0B0B0C) !important;
  color: var(--foreground);
  font-family: var(--font-sans);
  margin: 0 !important;
  min-height: 100vh;
}

.page-wrapper {
  display: flex;
  width: 100%;
  flex-direction: column;
  background: var(--Colors-Neutral-1000, #0B0B0C) !important;
  position: relative;
  min-height: 100vh;
}

/* Global App Chip Layout Class */
.app-chip {
  display: inline-flex !important;
  height: 20px !important;
  padding: var(--Spacing-Padding-2XS, 2px) var(--Spacing-Padding-S, 8px) !important;
  justify-content: center !important;
  align-items: center !important;
  gap: var(--Spacing-Padding-XS, 4px) !important;
  border-radius: var(--Radius-Round, 9999px) !important;
  white-space: nowrap;
  background: var(--Colors-Green-Alpha-10, rgba(31, 193, 107, 0.10)) !important;
  border: none !important;
  color: var(--Colors-Neutral-100, #FFF) !important;
  font-family: "Be Vietnam Pro", sans-serif !important;
  font-size: 12px !important;
  font-style: normal !important;
  font-weight: 500 !important;
  line-height: 15px !important;
}

/* Custom Featured Chip Style */
.featured-chip {
  border-radius: var(--Radius-Round, 9999px) !important;
  border: var(--Stroke-S, 1px) solid var(--Colors-Primary-400, #22C55E) !important;
  background: var(--Colors-Green-Alpha-10, rgba(31, 193, 107, 0.10)) !important;
  color: var(--Colors-Neutral-100, #FFF) !important;
  text-transform: uppercase !important;
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: #334155;
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: #475569;
}

/* Global CTA Button Styling Class */
.cta-btn {
  display: flex !important;
  padding: var(--Spacing-Padding-S, 8px) var(--Spacing-s, 12px) !important;
  justify-content: center !important;
  align-items: center !important;
  gap: var(--Spacing-Gap-XS, 8px) !important;
  align-self: stretch !important;
}

/* About Page Custom Layout Rules */
.about-hero-flex-container {
  display: flex !important;
  flex-direction: column !important;
  gap: 48px !important;
  width: 100% !important;
  align-items: center !important;
}
.about-hero-left-flex {
  display: block !important;
  width: 100% !important;
  max-width: 100% !important;
  flex: 0 0 100% !important;
}
.about-hero-right-flex {
  display: block !important;
  width: 100% !important;
  max-width: 100% !important;
  flex: 0 0 100% !important;
}

.about-exp-grid {
  display: grid !important;
  grid-template-columns: 1fr !important;
  gap: 32px !important;
  width: 100% !important;
}

.about-work-grid {
  display: grid !important;
  grid-template-columns: 1fr !important;
  gap: 32px !important;
  width: 100% !important;
}

.about-process-grid {
  display: grid !important;
  grid-template-columns: 1fr !important;
  gap: 0px !important;
  width: 100% !important;
}

.about-expert-grid {
  display: grid !important;
  grid-template-columns: 1fr !important;
  gap: 32px !important;
  width: 100% !important;
}

.about-edu-grid {
  display: grid !important;
  grid-template-columns: 1fr !important;
  gap: 24px !important;
  width: 100% !important;
}

@media (min-width: 640px) {
  .about-expert-grid {
    grid-template-columns: repeat(2, 1fr) !important;
  }
}

@media (min-width: 768px) {
  .about-work-grid {
    grid-template-columns: repeat(3, 1fr) !important;
  }
  .about-process-grid {
    grid-template-columns: repeat(2, 1fr) !important;
  }
}

@media (min-width: 1024px) {
  .about-hero-flex-container {
    flex-direction: row !important;
    gap: 64px !important;
  }
  .about-hero-left-flex {
    display: block !important;
    width: 25% !important;
    max-width: 25% !important;
    flex: 0 0 25% !important;
  }
  .about-hero-right-flex {
    display: block !important;
    width: 75% !important;
    max-width: 75% !important;
    flex: 0 0 75% !important;
  }
  .about-exp-grid {
    grid-template-columns: 1fr 3fr !important;
    gap: 64px !important;
  }
  .about-process-grid {
    grid-template-columns: repeat(4, 1fr) !important;
  }
  .about-expert-grid {
    grid-template-columns: repeat(4, 1fr) !important;
  }
  .about-edu-grid {
    grid-template-columns: repeat(2, 1fr) !important;
  }
}
